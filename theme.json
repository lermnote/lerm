{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"custom": true,
			"customDuotone": false,
			"palette": [
				{
					"slug": "primary",
					"color": "#0084ba",
					"name": "Primary"
				},
				{
					"slug": "primary-dark",
					"color": "#006a96",
					"name": "Primary Dark"
				},
				{
					"slug": "foreground",
					"color": "#2d2d2d",
					"name": "Foreground"
				},
				{
					"slug": "foreground-muted",
					"color": "#5d6777",
					"name": "Foreground Muted"
				},
				{
					"slug": "background",
					"color": "#ffffff",
					"name": "Background"
				},
				{
					"slug": "background-alt",
					"color": "#f8f9fa",
					"name": "Background Alt"
				},
				{
					"slug": "surface",
					"color": "#ffffff",
					"name": "Surface"
				},
				{
					"slug": "border",
					"color": "#e9ecef",
					"name": "Border"
				},
				{
					"slug": "header-bg",
					"color": "#ffffff",
					"name": "Header Background"
				},
				{
					"slug": "footer-bg",
					"color": "#333333",
					"name": "Footer Background"
				},
				{
					"slug": "footer-text",
					"color": "#dddddd",
					"name": "Footer Text"
				},
				{
					"slug": "accent",
					"color": "#cd2653",
					"name": "Accent"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				},
				{
					"slug": "black",
					"color": "#000000",
					"name": "Black"
				}
			],
			"duotone": []
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"slug": "system",
					"name": "System UI",
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, \"Noto Sans\", sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\""
				},
				{
					"slug": "lerm-icon",
					"name": "Lerm Icons",
					"fontFamily": "\"lerm-icons\", sans-serif",
					"fontFace": [
						{
							"fontFamily": "lerm-icons",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/lerm.woff"
							]
						}
					]
				}
			],
			"fontSizes": [
				{
					"slug": "xs",
					"size": "0.75rem",
					"name": "XS"
				},
				{
					"slug": "sm",
					"size": "0.875rem",
					"name": "Small"
				},
				{
					"slug": "base",
					"size": "1rem",
					"name": "Base"
				},
				{
					"slug": "md",
					"size": "1.125rem",
					"name": "Medium"
				},
				{
					"slug": "lg",
					"size": "1.375rem",
					"name": "Large"
				},
				{
					"slug": "xl",
					"size": "clamp(1.5rem, 3vw, 2rem)",
					"name": "XL"
				},
				{
					"slug": "2xl",
					"size": "clamp(1.75rem, 4vw, 2.5rem)",
					"name": "2XL"
				},
				{
					"slug": "3xl",
					"size": "clamp(2rem, 5vw, 3.5rem)",
					"name": "3XL"
				}
			]
		},
		"spacing": {
			"units": [
				"px",
				"em",
				"rem",
				"%"
			],
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"slug": "1",
					"size": "0.25rem",
					"name": "1"
				},
				{
					"slug": "2",
					"size": "0.5rem",
					"name": "2"
				},
				{
					"slug": "3",
					"size": "0.75rem",
					"name": "3"
				},
				{
					"slug": "4",
					"size": "1rem",
					"name": "4"
				},
				{
					"slug": "5",
					"size": "1.25rem",
					"name": "5"
				},
				{
					"slug": "6",
					"size": "1.5rem",
					"name": "6"
				},
				{
					"slug": "8",
					"size": "2rem",
					"name": "8"
				},
				{
					"slug": "10",
					"size": "2.5rem",
					"name": "10"
				},
				{
					"slug": "12",
					"size": "3rem",
					"name": "12"
				},
				{
					"slug": "16",
					"size": "4rem",
					"name": "16"
				},
				{
					"slug": "20",
					"size": "5rem",
					"name": "20"
				}
			]
		},
		"layout": {
			"contentSize": "760px",
			"wideSize": "1140px"
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"slug": "card",
					"shadow": "0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.05)",
					"name": "Card"
				},
				{
					"slug": "card-hover",
					"shadow": "0 4px 12px rgba(0,0,0,.1), 0 2px 4px rgba(0,0,0,.06)",
					"name": "Card Hover"
				},
				{
					"slug": "dropdown",
					"shadow": "0 8px 24px rgba(0,0,0,.12)",
					"name": "Dropdown"
				}
			]
		},
		"blocks": {
			"core/image": {
				"lightbox": {
					"enabled": true,
					"allowEditing": true
				}
			},
			"core/navigation": {
				"typography": {
					"fontSizes": true
				}
			}
		},
		"useRootPaddingAwareAlignments": true,
		"background": {
			"backgroundImage": true,
			"backgroundSize": true
		}
	},
	"styles": {
		"color": {
			"background": "var(--lerm-bg-body)",
			"text": "var(--lerm-color-text)"
		},
		"typography": {
			"fontFamily": "var(--lerm-font-family-base)",
			"fontSize": "var(--lerm-font-size-base)",
			"lineHeight": "var(--lerm-line-height-base)"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--6)"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--lerm-color-link)"
				},
				":hover": {
					"color": {
						"text": "var(--lerm-color-link-hover)"
					},
					"typography": {
						"textDecoration": "underline"
					}
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--2xl)",
					"fontWeight": "700",
					"lineHeight": "1.25"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xl)",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--lg)",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--md)",
					"fontWeight": "600"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--base)",
					"fontWeight": "600"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "600"
				}
			},
			"button": {
				"color": {
					"background": "var(--lerm-btn-hover-bg, var(--lerm-color-primary))",
					"text": "var(--lerm-btn-hover-color, #fff)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "500"
				},
				"border": {
					"radius": "0.375rem"
				},
				":hover": {
					"color": {
						"background": "var(--lerm-color-primary-hover)"
					}
				}
			}
		},
		"blocks": {
			"core/paragraph": {
				"spacing": {
					"margin": {
						"bottom": "var(--wp--preset--spacing--4)"
					}
				}
			},
			"core/image": {
				"border": {
					"radius": "0.375rem"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--lerm-color-border)"
				},
				"border": {
					"color": "var(--lerm-color-border)"
				}
			},
			"core/code": {
				"color": {
					"background": "var(--lerm-box-outer-bg, var(--lerm-bg-body))",
					"text": "var(--lerm-color-text)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)"
				},
				"border": {
					"radius": "0.375rem",
					"width": "1px",
					"color": "var(--lerm-color-border)"
				}
			},
			"core/quote": {
				"border": {
					"color": "var(--lerm-color-primary)",
					"style": "solid",
					"width": "0",
					"left": {
						"width": "4px"
					}
				},
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--6)"
					}
				},
				"color": {
					"text": "var(--lerm-color-text-muted, var(--lerm-color-text))"
				}
			},
			"core/table": {
				"border": {
					"color": "var(--lerm-color-border)",
					"style": "solid",
					"width": "1px"
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)"
				}
			},
			"core/post-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--2xl)",
					"fontWeight": "700",
					"lineHeight": "1.25"
				}
			},
			"core/post-excerpt": {
				"color": {
					"text": "var(--lerm-color-text-muted, var(--lerm-color-text))"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)"
				}
			},
			"core/post-date": {
				"color": {
					"text": "var(--lerm-color-text-muted, var(--lerm-color-text))"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xs)"
				}
			},
			"core/comment-content": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)"
				}
			}
		}
	},
	"customTemplates": [
		{
			"name": "template-full-width",
			"title": "Full Width",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "account",
			"title": "Account",
			"postTypes": [
				"page"
			]
		}
	],
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		},
		{
			"name": "sidebar",
			"title": "Sidebar",
			"area": "uncategorized"
		}
	],
	"patterns": []
}