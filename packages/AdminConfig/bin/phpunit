#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PHPUNIT_BIN="$ROOT_DIR/vendor/bin/phpunit"
PHPUNIT_CONFIG="$ROOT_DIR/phpunit.xml.dist"
DEFAULT_PHP_BIN="/mnt/d/xampp/php/php.exe"
PHP_BIN="${PHP_BIN:-$DEFAULT_PHP_BIN}"

to_runtime_path() {
	local path="$1"

	if [[ "$PHP_BIN" == *.exe && "$path" == /* ]]; then
		wslpath -w "$path"
		return
	fi

	printf '%s\n' "$path"
}

if [[ ! -f "$PHPUNIT_BIN" ]]; then
	echo "PHPUnit is not installed. Run ./bin/composer install first." >&2
	exit 1
fi

exec "$SCRIPT_DIR/php" "$(to_runtime_path "$PHPUNIT_BIN")" --configuration "$(to_runtime_path "$PHPUNIT_CONFIG")" "$@"
