#!/usr/bin/env bash
set -euo pipefail

DEFAULT_PHP_BIN="/mnt/d/xampp/php/php.exe"
PHP_BIN="${PHP_BIN:-$DEFAULT_PHP_BIN}"

if [[ "$PHP_BIN" == */* ]]; then
	if [[ ! -x "$PHP_BIN" ]]; then
		echo "PHP executable not found at: $PHP_BIN" >&2
		echo "Set PHP_BIN to your PHP CLI path and try again." >&2
		exit 1
	fi
elif ! command -v "$PHP_BIN" >/dev/null 2>&1; then
	echo "PHP executable not found in PATH: $PHP_BIN" >&2
	echo "Set PHP_BIN to your PHP CLI path and try again." >&2
	exit 1
fi

exec "$PHP_BIN" "$@"
