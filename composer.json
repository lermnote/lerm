{
	"name": "lerm/lerm",
	"type": "wordpress-theme",
	"version": "5.0.0",
	"description": "WordPress theme based on bootstrap",
	"keywords": [
		"WordPress",
		"Themes"
	],
	"authors": [
		{
			"name": "Lerm",
			"email": "admin@lerm.net",
			"homepage": "https://lerm.net",
			"role": "Developer"
		}
	],
	"repositories": [
		{
			"type": "vcs",
			"url": "https://github.com/lermnote/admin-config"
		}
	],
	"require": {
		"php": ">=8.0",
		"lerm/admin-config": "^0.4"
	},
	"autoload": {
		"psr-4": {
			"Lerm\\": "app/"
		},
		"files": [
			"app/View/Layout.php",
			"app/View/Icon.php",
			"app/Support/Utilities.php"
		]
	},
	"require-dev": {
		"squizlabs/php_codesniffer": "*",
		"wp-coding-standards/wpcs": "*"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}